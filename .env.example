# ============================================================
#  .env.example — Plantilla de configuración
#  Versión: 2.5.0
#
#  Uso:
#    cp .env.example .env
#    nano .env
#    docker compose up -d
#
#  El fichero .env es montado en el contenedor read-only en:
#    /etc/url-watchdog/.env
# ============================================================

# --- URLs a monitorear --------------------------------------
# Separa múltiples URLs con coma (sin espacios).
URLS="https://google.com,https://1.1.1.1"

# --- Comportamiento -----------------------------------------

# Minutos entre comprobaciones en modo normal (bajo consumo).
# En modo vigilancia (fallo activo) siempre se comprueba cada minuto.
# Mínimo: 1. Recomendado: 5-10.
WATCHDOG_INTERVAL_MINUTES=5

# Minutos de fallo continuo antes de actuar.
MAX_FAIL_MINUTES=10

# Timeout por petición HTTP (segundos).
HTTP_TIMEOUT=10

# Modo de detección de fallo:
#   "all"    → actúa solo si TODAS las URLs fallan (recomendado)
#   "any"    → actúa si CUALQUIERA falla
#   "quorum" → actúa si al menos FAIL_QUORUM URLs fallan
FAIL_MODE="all"

# Número de URLs que deben fallar para actuar (solo si FAIL_MODE=quorum).
FAIL_QUORUM=2

# Ciclos con fallos parciales antes de alertar (modos "all" y "quorum").
INSTABILITY_THRESHOLD=3

# Latencia (ms) a partir de la cual alertar aunque la URL responda.
# La alerta se envía solo una vez por episodio y se recupera sola al bajar.
# 0 = deshabilitado. Recomendado: 2000 (2 s).
LATENCY_WARN_MS=0

# Minutos de corte activo tras los cuales se envía una alerta de escalada.
# Lista separada por comas; cada umbral se notifica una sola vez.
# Ejemplo: 15,60 → alerta a los 15 min y a la hora de corte.
ESCALATE_MINUTES="15,60"

# --- FritzBox TR-064 ----------------------------------------
FRITZ_IP="192.168.178.1"
FRITZ_USER=""
FRITZ_PASSWORD=""

# Minutos esperando tras reconexión WAN antes de verificar.
FRITZ_WAN_WAIT_MINUTES=2

# Minutos esperando tras reboot Fritz antes de reiniciar el servidor.
FRITZ_WAIT_MINUTES=10

# Segundos entre comprobaciones de reboot inesperado de la Fritz.
FRITZ_REBOOT_CHECK_INTERVAL=300

# --- Certificados TLS ---------------------------------------
# Días antes de la expiración para alertar. 0 = deshabilitar.
CERT_EXPIRY_WARN_DAYS=14

# --- Telegram -----------------------------------------------
TELEGRAM_TOKEN=""
TELEGRAM_CHAT_ID=""
ALLOWED_CHAT_IDS=""
TELEGRAM_MAX_RETRIES=3
TELEGRAM_RETRY_DELAY=5
BOT_POLL_TIMEOUT=30

# Segundos para confirmar operaciones peligrosas (/restart server, /reboot_server).
CONFIRM_TIMEOUT=30

# --- Log ----------------------------------------------------
LOG_FILE="/var/log/url-watchdog.log"
LOG_MAX_BYTES=524288
LOG_DEFAULT_LINES=20

# --- Informes -----------------------------------------------
# Hora del informe diario y semanal (lunes). Formato HH:MM.
DAILY_REPORT_TIME="08:00"

# --- Alertas de IP ------------------------------------------
# Cambios de IP pública diarios antes de alertar por anomalía.
IP_CHANGE_ALERT_THRESHOLD=3

# --- Diagnóstico (/traceroute, /speedtest) ------------------
TRACEROUTE_DEFAULT_HOST="1.1.1.1"
SPEEDTEST_URLS="https://speed.cloudflare.com/__down?bytes=10000000,https://download.thinkbroadband.com/10MB.zip,https://proof.ovh.net/files/10Mb.dat"

# --- Historial de incidentes --------------------------------
INCIDENTS_FILE="/var/lib/url-watchdog/incidents.json"
INCIDENTS_MAX_ENTRIES=500
HISTORY_DEFAULT_N=5

# --- Proxmox — reboot vía API (opcional) --------------------
# Cuando el watchdog agota todas las fases de recuperación, usa la API REST
# de Proxmox para reiniciar el nodo. Dejar vacío para usar /sbin/reboot directo.
#
# El token debe tener el permiso Sys.PowerMgmt en el nodo.
# TOKEN_ID: usuario@realm!nombre  (ej. root@pam!watchdog)
# SECRET:   el UUID que Proxmox muestra al crear el token
PROXMOX_HOST=""
PROXMOX_NODE=""
PROXMOX_TOKEN_ID=""
PROXMOX_TOKEN_SECRET=""

# --- Rutas de estado interno — no modificar -----------------
# Los scripts bash requieren estas variables. Los valores son fijos
# dentro del contenedor y no deben cambiarse en una instalación estándar.

STATE_DIR="/run/url-watchdog"

STATE_FILE="/run/url-watchdog/watchdog.fail"
STATE_IP_FILE="/run/url-watchdog/watchdog.ip"
STATE_WAN_FILE="/run/url-watchdog/watchdog.wan"
STATE_FRITZ_FILE="/run/url-watchdog/watchdog.fritz"
STATE_SILENCE_FILE="/run/url-watchdog/watchdog.silence"
STATE_FRITZ_UPTIME_FILE="/run/url-watchdog/watchdog.fritz-uptime"
STATE_IP_CHANGES_FILE="/run/url-watchdog/watchdog.ip-changes"
STATE_CONFIRM_FILE="/run/url-watchdog/watchdog.confirm"
NOTIFY_QUEUE_FILE="/run/url-watchdog/watchdog.notify-queue"
STATE_PARTIAL_FAIL_FILE="/run/url-watchdog/watchdog.partial-fail"
STATE_LAN_FAIL_FILE="/run/url-watchdog/watchdog.lan-fail"
STATE_TLS_CHECK_FILE="/var/lib/url-watchdog/watchdog.tls-check"

BOT_PID_FILE="/run/url-watchdog/telegram-bot.pid"
BOT_START_REASON_FILE="/run/url-watchdog/telegram-bot.start-reason"
BOT_OFFSET_FILE="/var/lib/url-watchdog/telegram-bot.offset"
