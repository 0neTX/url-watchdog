# ============================================================
#  url-watchdog.env — Plantilla de configuración (sin credenciales)
#  Versión: 2.2.0
#  Ubicación real:  /etc/url-watchdog/.env
#  Permisos reales: chmod 600 /etc/url-watchdog/.env
# ============================================================

# --- URLs a monitorear --------------------------------------
# Separa múltiples URLs con coma (sin espacios)
URLS="https://google.com,https://1.1.1.1"

# --- Comportamiento -----------------------------------------

# Minutos de fallo continuo antes de actuar
MAX_FAIL_MINUTES=10

# Timeout por petición HTTP (segundos)
HTTP_TIMEOUT=10

# Modo de detección de fallo:
#   "all"    → actúa solo si TODAS las URLs fallan (recomendado)
#   "any"    → actúa si CUALQUIERA falla
#   "quorum" → actúa si al menos FAIL_QUORUM URLs fallan
FAIL_MODE="all"

# Número de URLs que deben fallar para actuar (solo si FAIL_MODE=quorum)
FAIL_QUORUM=2

# --- Inestabilidad parcial (#7) -----------------------------
# Ciclos con fallos parciales (sin alcanzar el umbral) antes de alertar.
# Solo aplica en modos "all" y "quorum".
INSTABILITY_THRESHOLD=3

# --- FritzBox TR-064 ----------------------------------------
FRITZ_IP="192.168.178.1"
FRITZ_USER=""
FRITZ_PASSWORD=""

# Minutos esperando tras reconexión WAN antes de verificar
FRITZ_WAN_WAIT_MINUTES=2

# Minutos esperando tras reboot Fritz antes de reiniciar servidor
FRITZ_WAIT_MINUTES=10

# Intervalo (segundos) entre comprobaciones de reboot inesperado Fritz
FRITZ_REBOOT_CHECK_INTERVAL=300

# --- Certificados TLS (#8) ----------------------------------
# Días antes de la expiración para alertar. 0 = deshabilitar.
CERT_EXPIRY_WARN_DAYS=14

# --- Telegram -----------------------------------------------
TELEGRAM_TOKEN=""
TELEGRAM_CHAT_ID=""
ALLOWED_CHAT_IDS=""
TELEGRAM_MAX_RETRIES=3
TELEGRAM_RETRY_DELAY=5
BOT_POLL_TIMEOUT=30
CONFIRM_TIMEOUT=30

# --- Log ----------------------------------------------------
LOG_FILE="/var/log/url-watchdog.log"
LOG_MAX_BYTES=524288
LOG_DEFAULT_LINES=20

# --- Informes -----------------------------------------------
# Hora del informe diario y semanal (lunes). Formato HH:MM.
DAILY_REPORT_TIME="08:00"

# --- Alertas de IP ------------------------------------------
IP_CHANGE_ALERT_THRESHOLD=3

# --- Diagnóstico (/traceroute, /speedtest) ------------------
TRACEROUTE_DEFAULT_HOST="1.1.1.1"
SPEEDTEST_URLS="https://speed.cloudflare.com/__down?bytes=10000000,https://speed.hetzner.de/10MB.bin,https://proof.ovh.net/files/10Mb.dat"

# --- Historial de incidentes --------------------------------
INCIDENTS_FILE="/var/lib/url-watchdog/incidents.json"
INCIDENTS_MAX_ENTRIES=500
HISTORY_DEFAULT_N=5

# --- Directorios de estado ----------------------------------
# STATE_DIR se crea automáticamente en cada boot via tmpfiles.d
STATE_DIR="/run/url-watchdog"

STATE_FILE="/run/url-watchdog/watchdog.fail"
STATE_IP_FILE="/run/url-watchdog/watchdog.ip"
STATE_WAN_FILE="/run/url-watchdog/watchdog.wan"
STATE_FRITZ_FILE="/run/url-watchdog/watchdog.fritz"
STATE_SILENCE_FILE="/run/url-watchdog/watchdog.silence"
STATE_FRITZ_UPTIME_FILE="/run/url-watchdog/watchdog.fritz-uptime"
STATE_IP_CHANGES_FILE="/run/url-watchdog/watchdog.ip-changes"
STATE_CONFIRM_FILE="/run/url-watchdog/watchdog.confirm"
NOTIFY_QUEUE_FILE="/run/url-watchdog/watchdog.notify-queue"

# Nuevo en v2.2.0:
STATE_PARTIAL_FAIL_FILE="/run/url-watchdog/watchdog.partial-fail"
STATE_LAN_FAIL_FILE="/run/url-watchdog/watchdog.lan-fail"
# TLS check en /var/lib para que sobreviva reboots y se ejecute realmente 1 vez/día
STATE_TLS_CHECK_FILE="/var/lib/url-watchdog/watchdog.tls-check"

BOT_PID_FILE="/run/url-watchdog/telegram-bot.pid"
BOT_START_REASON_FILE="/run/url-watchdog/telegram-bot.start-reason"

# Offset en /var/lib: persiste entre reboots, evita reprocesar mensajes
BOT_OFFSET_FILE="/var/lib/url-watchdog/telegram-bot.offset"

# --- URLs de actualización (/update) ------------------------
# Cambia 0NETX/URL-WATCHDOG por los valores reales antes de publicar.
# Genera SHA256SUMS con:
#   sha256sum url-watchdog-*.sh telegram-bot.sh > SHA256SUMS
UPDATE_URL_COMMON="https://raw.githubusercontent.com/0NETX/URL-WATCHDOG/main/url-watchdog-common.sh"
UPDATE_URL_WATCHDOG="https://raw.githubusercontent.com/0NETX/URL-WATCHDOG/main/url-watchdog.sh"
UPDATE_URL_BOT="https://raw.githubusercontent.com/0NETX/URL-WATCHDOG/main/telegram-bot.sh"
UPDATE_URL_REPORT="https://raw.githubusercontent.com/0NETX/URL-WATCHDOG/main/url-watchdog-report.sh"
UPDATE_URL_CHECKSUMS="https://raw.githubusercontent.com/0NETX/URL-WATCHDOG/main/SHA256SUMS"
